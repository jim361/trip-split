# Firebase Emulator/Functions의 일반 환경변수 예시입니다.
FUNCTIONS_REGION=asia-northeast3
SHARE_CODE_LENGTH=8

# OCR 담당자가 parseReceipt를 구현할 때 사용하는 경계입니다.
# 실제 secret은 이 파일이나 Git에 넣지 말고 다음처럼 등록합니다.
# firebase functions:secrets:set CLOVA_OCR_SECRET
CLOVA_OCR_INVOKE_URL=
# CLOVA_OCR_SECRET=functions secret으로만 관리
