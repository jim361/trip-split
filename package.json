{
  "name": "trip-split",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "functions"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && npm run build --workspace functions",
    "build:pages": "npm run typecheck && vite build --mode pages && node scripts/prepare-pages.mjs",
    "preview": "vite preview",
    "preview:pages": "vite preview --mode pages",
    "typecheck": "tsc -b --pretty false && npm run typecheck --workspace functions",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run && npm run test --workspace functions",
    "test:watch": "vitest",
    "test:emulator": "npm run build --workspace functions && firebase emulators:exec --project demo-trip-split --only auth,firestore,functions \"vitest run --config vitest.emulator.config.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^15.23.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
